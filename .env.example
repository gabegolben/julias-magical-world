# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Enables seeding the shared story_cache (clients can only READ
# it, so they can never poison re-served content). Unset = cache never fills.
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DIRECT_URL=

# AI providers — bake-off 2026-07-17 pinned claude-haiku-4-5 (stories) and
# gpt-image-1-mini (art). STORY_MODEL_PREMIUM upgrades paid tiers later.
# Re-compare candidates anytime: `npm run bakeoff -w @jmw/ai`.
STORY_MODEL=claude-haiku-4-5
STORY_MODEL_PREMIUM=
ILLUSTRATION_MODEL=gpt-image-1-mini
REVIEW_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Per-user daily AI caps (counted from the ai_usage ledger). Unset = defaults
# shown. IMAGE_DAILY_LIMIT=0 disables illustration generation (procedural art
# only) without removing the OpenAI key.
STORY_DAILY_LIMIT=15
IMAGE_DAILY_LIMIT=40

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
